# Supabase — Project Settings > API (use a anon key)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=sua_anon_key_aqui

# Z-API — painel da instância em https://app.z-api.io
ZAPI_INSTANCE_ID=sua_instancia_aqui
ZAPI_TOKEN=seu_token_aqui
ZAPI_CLIENT_TOKEN=seu_client_token_aqui

# Opcionais (já têm valor padrão)
TABELA_CONTATOS=contatos
INTERVALO_ENTRE_ENVIOS=2
